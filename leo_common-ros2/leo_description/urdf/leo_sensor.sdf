  <gazebo reference="realsense_link">
    <sensor name="depth_camera" type="rgbd_camera">
      <always_on>1</always_on>
      <update_rate>5</update_rate>
      <camera name="depth_camera">
        <horizontal_fov>1.51844</horizontal_fov>
        <!--87 degrees-->
        <lens>
          <intrinsics>
            <!-- fx = fy = width / ( 2 * tan (hfov / 2 ) ) -->
            <fx>554.25469</fx>
            <fy>554.25469</fy>
            <!-- cx = ( width + 1 ) / 2 -->
            <cx>320.5</cx>
            <!-- cy = ( height + 1 ) / 2 -->
            <cy>240.5</cy>
            <s>0</s>
          </intrinsics>
        </lens>
        <distortion>
          <k1>0.0</k1>
          <k2>0.0</k2>
          <k3>0.0</k3>
          <p1>0.0</p1>
          <p2>0.0</p2>
          <center>0.5 0.5</center>
        </distortion>
        <image>
          <width>64</width>
          <height>48</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.01</near>
          <far>300</far>
        </clip>
        <depth_camera>
          <clip>
            <near>0.1</near>
            <far>10</far>
          </clip>
        </depth_camera>
        <noise>
          <type>gaussian</type>
          <mean>0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>depth_camera</topic>
    </sensor>
  </gazebo>
  <!-- rocker differential -->
  <gazebo>
    <plugin filename="libleo_gz_differential_plugin.so" name="leo_gz::DifferentialSystem">
      <jointA>rocker_L_joint</jointA>
      <jointB>rocker_R_joint</jointB>
      <forceConstant>100.0</forceConstant>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libignition-gazebo-joint-state-publisher-system.so" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgz-sim-diff-drive-system.so" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_FL_joint</left_joint>
      <right_joint>wheel_FR_joint</right_joint>
      <left_joint>wheel_RL_joint</left_joint>
      <right_joint>wheel_RR_joint</right_joint>
      <wheel_separation>0.358</wheel_separation>
      <wheel_radius>0.0625</wheel_radius>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <max_linear_acceleration>2.5</max_linear_acceleration>
      <max_angular_acceleration>3</max_angular_acceleration>
      <min_linear_acceleration>-2.5</min_linear_acceleration>
      <min_angular_acceleration>-3</min_angular_acceleration>
    </plugin>
  </gazebo>
  <gazebo reference="base_footprint">
    <sensor name="contact_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <contact>
        <collision>base_footprint_fixed_joint_lump__base_collision_collision</collision>
      </contact>
      <visualize>true</visualize>
      <plugin filename="libignition-gazebo6-contact-system.so" name="ignition::gazebo::systems::Contact"/>
    </sensor>
  </gazebo>
  <gazebo reference="front_bumper">
    <!-- Contact sensor -->
    <sensor name="front_bumper_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <contact>
        <collision>front_bumper_collision</collision>
      </contact>
      <visualize>true</visualize>
      <plugin filename="libignition-gazebo6-contact-system.so" name="ignition::gazebo::systems::Contact"/>
    </sensor>
  </gazebo>
