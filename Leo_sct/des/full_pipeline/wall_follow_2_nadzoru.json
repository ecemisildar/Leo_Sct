{
  "rationale": "This supervisor prioritizes wall-following on the left, avoids oscillations by consistently preferring right turns for obstacle avoidance, and uses helper states for atomic actions and recovery. Only one controllable is enabled per state (except obs_front, which allows both move_backward and full_rotate for robust escape). Uncontrollable events are total, and commit states are one-shot. The design ensures safe, deterministic, and consistent wall-following behavior.",
  "new_states": [
    "forward_commit",
    "rotate_commit_cw",
    "rotate_commit_ccw",
    "scan_full",
    "recover_back"
  ],
