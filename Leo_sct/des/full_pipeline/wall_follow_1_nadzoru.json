    "(\"clear\", \"obstacle_front\", \"obs_front\")",
    "(\"clear\", \"obstacle_left\", \"obs_left\")",
    "(\"clear\", \"obstacle_right\", \"obs_right\")",
    "(\"clear\", \"marker_seen\", \"marker_approach\")",
    "(\"clear\", \"marker_close\", \"clear\")",
    "(\"clear\", \"move_forward\", \"forward_commit\")",
    "(\"forward_commit\", \"path_clear\", \"forward_commit\")",
    "(\"forward_commit\", \"obstacle_front\", \"obs_front\")",
    "(\"forward_commit\", \"obstacle_left\", \"obs_left\")",
    "(\"forward_commit\", \"obstacle_right\", \"obs_right\")",
    "(\"forward_commit\", \"marker_seen\", \"marker_approach\")",
    "(\"forward_commit\", \"marker_close\", \"forward_commit\")",
    "(\"forward_commit\", \"move_forward\", \"forward_commit\")",
    "(\"obs_front\", \"path_clear\", \"clear\")",
    "(\"obs_front\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_front\", \"obstacle_left\", \"obs_left\")",
    "(\"obs_front\", \"obstacle_right\", \"obs_right\")",
    "(\"obs_front\", \"marker_seen\", \"obs_front\")",
    "(\"obs_front\", \"marker_close\", \"obs_front\")",
    "(\"obs_front\", \"move_backward\", \"escape_backup\")",
    "(\"obs_front\", \"full_rotate\", \"rotate_commit_cw\")",
    "(\"escape_backup\", \"path_clear\", \"clear\")",
    "(\"escape_backup\", \"obstacle_front\", \"obs_front\")",
    "(\"escape_backup\", \"obstacle_left\", \"obs_left\")",
    "(\"escape_backup\", \"obstacle_right\", \"obs_right\")",
    "(\"escape_backup\", \"marker_seen\", \"escape_backup\")",
    "(\"escape_backup\", \"marker_close\", \"escape_backup\")",
    "(\"escape_backup\", \"move_backward\", \"escape_backup\")",
    "(\"obs_left\", \"path_clear\", \"clear\")",
    "(\"obs_left\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_left\", \"obstacle_left\", \"obs_left\")",
