    "(\"obs_right\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_right\", \"obstacle_left\", \"obs_left\")",
    "(\"obs_right\", \"obstacle_right\", \"obs_right\")",
    "(\"obs_right\", \"marker_seen\", \"obs_right\")",
    "(\"obs_right\", \"marker_close\", \"obs_right\")",
    "(\"obs_right\", \"rotate_counterclockwise\", \"rotate_commit_ccw\")",
    "(\"rotate_commit_cw\", \"path_clear\", \"forward_commit\")",
    "(\"rotate_commit_cw\", \"obstacle_front\", \"rotate_commit_cw\")",
    "(\"rotate_commit_cw\", \"obstacle_left\", \"rotate_commit_cw\")",
    "(\"rotate_commit_cw\", \"obstacle_right\", \"rotate_commit_cw\")",
    "(\"rotate_commit_cw\", \"marker_seen\", \"rotate_commit_cw\")",
