    "(\"rotate_commit_ccw\", \"obstacle_left\", \"rotate_commit_ccw\")",
    "(\"rotate_commit_ccw\", \"obstacle_right\", \"rotate_commit_ccw\")",
    "(\"rotate_commit_ccw\", \"marker_seen\", \"rotate_commit_ccw\")",
    "(\"rotate_commit_ccw\", \"marker_close\", \"rotate_commit_ccw\")",
    "(\"rotate_commit_ccw\", \"rotate_counterclockwise\", \"rotate_commit_ccw\")",
    "(\"marker_approach\", \"path_clear\", \"marker_approach\")",
    "(\"marker_approach\", \"obstacle_front\", \"obs_front\")",
    "(\"marker_approach\", \"obstacle_left\", \"obs_left\")",
