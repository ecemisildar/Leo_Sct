{
  "rationale": "This supervisor structure prioritizes safe forward progress, robust obstacle avoidance, and clear, non-oscillatory recovery from obstacles. Commit states ensure actions are completed before reevaluation. Only one primary controllable action is available per state (except obs_front, which allows both move_backward and full_rotate for escape). Helper states manage recovery and marker approach. All uncontrollable events are handled in every state.",
  "new_states": [
    "rotate_commit_cw",
    "rotate_commit_ccw",
    "forward_commit",
    "marker_approach",
    "escape_backup"
  ],
  "transitions": [
