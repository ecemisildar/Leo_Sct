// dot output generated by libFAUDES vGenerator
digraph "Sup_reactive_motion" {
  rankdir=LR
  node [shape=rectangle, style=rounded];

  // initial states
  dot_dummyinit_1 [shape=none, label="", width="0.0", height="0.0" ];
  dot_dummyinit_1 -> "q|clear";

  // mstates
  "q|clear" [ label=<<TABLE BORDER="0"><TR><TD>q|clear</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_front" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_front</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_left" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_left</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_right" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_right</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|crowded" [ label=<<TABLE BORDER="0"><TR><TD>q|crowded</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];

  // rest of stateset

  // transition relation
  "q|clear" -> "q|clear" [label="move_forward, 
rotate_clockwise, 
rotate_counterclockwise, 
random_walk, 
slow_down, 
speed_up, 
path_clear"];
  "q|clear" -> "q|obs_front" [label="obstacle_front"];
  "q|clear" -> "q|obs_left" [label="obstacle_left"];
  "q|clear" -> "q|obs_right" [label="obstacle_right"];
  "q|clear" -> "q|crowded" [label="crowd_detected"];
  "q|obs_front" -> "q|clear" [label="full_rotate, 
path_clear"];
  "q|obs_front" -> "q|obs_front" [label="random_walk, 
obstacle_front"];
  "q|obs_front" -> "q|obs_left" [label="rotate_counterclockwise, 
obstacle_left"];
  "q|obs_front" -> "q|obs_right" [label="rotate_clockwise, 
obstacle_right"];
  "q|obs_front" -> "q|crowded" [label="crowd_detected"];
  "q|obs_left" -> "q|clear" [label="move_forward, 
rotate_clockwise, 
path_clear"];
  "q|obs_left" -> "q|obs_front" [label="obstacle_front"];
  "q|obs_left" -> "q|obs_left" [label="random_walk, 
obstacle_left"];
  "q|obs_left" -> "q|obs_right" [label="obstacle_right"];
  "q|obs_left" -> "q|crowded" [label="crowd_detected"];
  "q|obs_right" -> "q|clear" [label="move_forward, 
rotate_counterclockwise, 
path_clear"];
  "q|obs_right" -> "q|obs_front" [label="obstacle_front"];
  "q|obs_right" -> "q|obs_left" [label="obstacle_left"];
  "q|obs_right" -> "q|obs_right" [label="random_walk, 
obstacle_right"];
  "q|obs_right" -> "q|crowded" [label="crowd_detected"];
  "q|crowded" -> "q|clear" [label="path_clear"];
  "q|crowded" -> "q|crowded" [label="full_rotate, 
random_walk, 
slow_down, 
obstacle_front, 
obstacle_left, 
obstacle_right, 
crowd_detected"];
}
