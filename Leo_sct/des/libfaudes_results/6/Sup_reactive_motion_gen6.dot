// dot output generated by libFAUDES vGenerator
digraph "Sup_reactive_motion" {
  rankdir=LR
  node [shape=rectangle, style=rounded];

  // initial states
  dot_dummyinit_1 [shape=none, label="", width="0.0", height="0.0" ];
  dot_dummyinit_1 -> "q|clear";

  // mstates
  "q|clear" [ label=<<TABLE BORDER="0"><TR><TD>q|clear</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_front" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_front</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_left" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_left</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|obs_right" [ label=<<TABLE BORDER="0"><TR><TD>q|obs_right</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];
  "q|oscillate_detected" [ label=<<TABLE BORDER="0"><TR><TD>q|oscillate_detected</TD><TD WIDTH="2"></TD><TD BGCOLOR="black" BORDER="0" WIDTH="8"></TD></TR></TABLE>>];

  // rest of stateset

  // transition relation
  "q|clear" -> "q|clear" [label="move_forward, 
move_backward, 
random_walk, 
path_clear"];
  "q|clear" -> "q|obs_front" [label="obstacle_front"];
  "q|clear" -> "q|obs_left" [label="obstacle_left"];
  "q|clear" -> "q|obs_right" [label="obstacle_right"];
  "q|obs_front" -> "q|clear" [label="full_rotate, 
path_clear"];
  "q|obs_front" -> "q|obs_front" [label="move_backward, 
obstacle_front"];
  "q|obs_front" -> "q|obs_left" [label="obstacle_left"];
  "q|obs_front" -> "q|obs_right" [label="obstacle_right"];
  "q|obs_left" -> "q|clear" [label="rotate_clockwise, 
path_clear"];
  "q|obs_left" -> "q|obs_front" [label="obstacle_front"];
  "q|obs_left" -> "q|obs_left" [label="move_backward, 
obstacle_left"];
  "q|obs_left" -> "q|oscillate_detected" [label="obstacle_right"];
  "q|obs_right" -> "q|clear" [label="rotate_counterclockwise, 
path_clear"];
  "q|obs_right" -> "q|obs_front" [label="obstacle_front"];
  "q|obs_right" -> "q|obs_right" [label="move_backward, 
obstacle_right"];
  "q|obs_right" -> "q|oscillate_detected" [label="obstacle_left"];
  "q|oscillate_detected" -> "q|clear" [label="full_rotate, 
path_clear"];
  "q|oscillate_detected" -> "q|obs_front" [label="obstacle_front"];
  "q|oscillate_detected" -> "q|obs_left" [label="obstacle_left"];
  "q|oscillate_detected" -> "q|obs_right" [label="obstacle_right"];
}
