    "SetTransition(\"clear\", \"rotate_clockwise\", \"clear\")",
    "SetTransition(\"clear\", \"rotate_counterclockwise\", \"clear\")",
    "SetTransition(\"clear\", \"full_rotate\", \"scan\")",
    "SetTransition(\"clear\", \"random_walk\", \"clear\")",
    "SetTransition(\"obs_front\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_front\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_front\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_front\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_front\", \"rotate_clockwise\", \"scan\")",
    "SetTransition(\"obs_front\", \"rotate_counterclockwise\", \"scan\")",
