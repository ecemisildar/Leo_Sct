{
  "rationale": "To ensure efficient, systematic coverage and safety, the supervisor uses a wall-following approach with helper states for turning and resuming coverage after obstacle encounters. Each state handles all uncontrollable events. Forward movement is only allowed when clear, and oscillations are avoided by requiring full rotations or directed turns after obstacle detection.",
  "new_states": [
    "clear",
    "obs_front",
    "obs_left",
    "obs_right",
    "turning_left",
    "turning_right",
    "scanning"
  ],
  "transitions": [
    "SetTransition(\"clear\", \"path_clear\", \"clear\")",
    "SetTransition(\"clear\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"clear\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"clear\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"clear\", \"move_forward\", \"clear\")",
    "SetTransition(\"clear\", \"rotate_clockwise\", \"turning_right\")",
    "SetTransition(\"clear\", \"rotate_counterclockwise\", \"turning_left\")",
    "SetTransition(\"obs_front\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_front\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_front\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_front\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_front\", \"rotate_counterclockwise\", \"turning_left\")",
    "SetTransition(\"obs_front\", \"full_rotate\", \"scanning\")",
    "SetTransition(\"obs_left\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_left\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_left\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_left\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_left\", \"rotate_clockwise\", \"turning_right\")",
    "SetTransition(\"obs_right\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_right\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_right\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_right\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_right\", \"rotate_counterclockwise\", \"turning_left\")",
    "SetTransition(\"turning_left\", \"path_clear\", \"clear\")",
    "SetTransition(\"turning_left\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"turning_left\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"turning_left\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"turning_left\", \"move_forward\", \"clear\")",
    "SetTransition(\"turning_right\", \"path_clear\", \"clear\")",
    "SetTransition(\"turning_right\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"turning_right\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"turning_right\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"turning_right\", \"move_forward\", \"clear\")",
    "SetTransition(\"scanning\", \"path_clear\", \"clear\")",
    "SetTransition(\"scanning\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"scanning\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"scanning\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"scanning\", \"rotate_clockwise\", \"scanning\")",
    "SetTransition(\"scanning\", \"rotate_counterclockwise\", \"scanning\")"
  ],
  "coverage_strategy": [
    "Use wall-following to systematically traverse the arena edges and cover all space.",
    "On encountering obstacles, turn away and resume forward movement only when path is clear.",
    "Initiate a full rotation (scanning) if blocked on all sides to find new open paths.",
    "Avoid oscillations by requiring a turn or scan before resuming movement after obstacle detection.",
    "Prioritize forward movement in clear state, use directed turns when obstacles are detected."
  ]
