    "SetTransition(\"obs_front\", \"rotate_counterclockwise\", \"sweep_left\")",
    "SetTransition(\"obs_front\", \"full_rotate\", \"clear\")",
    "SetTransition(\"obs_left\", \"path_clear\", \"clear\")",
