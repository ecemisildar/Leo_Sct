    "SetTransition(\"obs_front\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_front\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_front\", \"obstacle_right\", \"obs_right\")",
