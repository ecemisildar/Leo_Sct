    "SetTransition(\"obs_front\", \"full_rotate\", \"obs_front\")",
    "SetTransition(\"obs_front\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_front\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_front\", \"path_clear\", \"wall_follow_left\")",
    "SetTransition(\"obs_left\", \"move_forward\", \"wall_follow_left\")",
