    "SetTransition(\"obs_right\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_right\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_right\", \"path_clear\", \"clear\")",
    "SetTransition(\"wall_follow_left\", \"move_forward\", \"wall_follow_left\")",
