    "SetTransition(\"sweeping\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"sweeping\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"sweeping\", \"move_forward\", \"sweeping\")",
    "SetTransition(\"sweeping\", \"rotate_clockwise\", \"clear\")",
    "SetTransition(\"sweeping\", \"rotate_counterclockwise\", \"clear\")",
