{
  "rationale": "To ensure systematic area coverage and safe wall-following, we introduce helper states to distinguish between 'following left wall', 'turning to find wall', and 'navigating corners'. All uncontrollable events are handled in each state. The supervisor never allows moving forward if an obstacle is present, and encourages rotating to follow walls rather than oscillating or backing up unnecessarily.",
  "new_states": [
    "clear",
    "obs_front",
    "obs_left",
    "obs_right",
    "follow_left_wall",
    "turn_corner_left",
    "turn_corner_right"
  ],
  "transitions": [
    "(\"clear\", \"path_clear\", \"follow_left_wall\")",
    "(\"clear\", \"obstacle_front\", \"obs_front\")",
    "(\"clear\", \"obstacle_left\", \"obs_left\")",
    "(\"clear\", \"obstacle_right\", \"obs_right\")",
    "(\"obs_front\", \"path_clear\", \"follow_left_wall\")",
    "(\"obs_front\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_front\", \"obstacle_left\", \"turn_corner_right\")",
    "(\"obs_front\", \"obstacle_right\", \"turn_corner_left\")",
    "(\"obs_left\", \"path_clear\", \"follow_left_wall\")",
    "(\"obs_left\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_left\", \"obstacle_left\", \"obs_left\")",
    "(\"obs_left\", \"obstacle_right\", \"obs_right\")",
    "(\"obs_right\", \"path_clear\", \"follow_left_wall\")",
    "(\"obs_right\", \"obstacle_front\", \"obs_front\")",
    "(\"obs_right\", \"obstacle_left\", \"obs_left\")",
    "(\"obs_right\", \"obstacle_right\", \"obs_right\")",
    "(\"follow_left_wall\", \"path_clear\", \"follow_left_wall\")",
    "(\"follow_left_wall\", \"obstacle_front\", \"obs_front\")",
    "(\"follow_left_wall\", \"obstacle_left\", \"obs_left\")",
    "(\"follow_left_wall\", \"obstacle_right\", \"obs_right\")",
    "(\"turn_corner_left\", \"path_clear\", \"follow_left_wall\")",
    "(\"turn_corner_left\", \"obstacle_front\", \"obs_front\")",
    "(\"turn_corner_left\", \"obstacle_left\", \"obs_left\")",
    "(\"turn_corner_left\", \"obstacle_right\", \"obs_right\")",
    "(\"turn_corner_right\", \"path_clear\", \"follow_left_wall\")",
    "(\"turn_corner_right\", \"obstacle_front\", \"obs_front\")",
    "(\"turn_corner_right\", \"obstacle_left\", \"obs_left\")",
    "(\"turn_corner_right\", \"obstacle_right\", \"obs_right\")",
    "(\"clear\", \"move_forward\", \"clear\")",
    "(\"clear\", \"rotate_counterclockwise\", \"clear\")",
    "(\"clear\", \"rotate_clockwise\", \"clear\")",
    "(\"obs_front\", \"rotate_counterclockwise\", \"turn_corner_left\")",
    "(\"obs_front\", \"rotate_clockwise\", \"turn_corner_right\")",
    "(\"obs_left\", \"move_forward\", \"obs_left\")",
    "(\"obs_left\", \"rotate_clockwise\", \"obs_left\")",
    "(\"obs_right\", \"move_forward\", \"obs_right\")",
    "(\"obs_right\", \"rotate_counterclockwise\", \"obs_right\")",
    "(\"follow_left_wall\", \"move_forward\", \"follow_left_wall\")",
    "(\"follow_left_wall\", \"rotate_counterclockwise\", \"follow_left_wall\")",
    "(\"turn_corner_left\", \"rotate_counterclockwise\", \"turn_corner_left\")",
    "(\"turn_corner_left\", \"move_forward\", \"turn_corner_left\")",
    "(\"turn_corner_right\", \"rotate_clockwise\", \"turn_corner_right\")",
    "(\"turn_corner_right\", \"move_forward\", \"turn_corner_right\")"
  ],
  "coverage_strategy": [
    "Prioritize following the left wall when possible.",
    "At corners or dead-ends, rotate (counterclockwise for left wall following) to find a new wall.",
    "Never allow moving forward into obstacles.",
    "Encourage continuous progression along walls, avoiding oscillations or unnecessary reversals.",
    "When path is clear, transition to systematic wall-following rather than random walk."
  ]
