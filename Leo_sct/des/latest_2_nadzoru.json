    "SetTransition(\"obs_front\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_left\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_left\", \"obstacle_front\", \"obs_front\")",
    "SetTransition(\"obs_left\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"obs_left\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"obs_right\", \"path_clear\", \"clear\")",
    "SetTransition(\"obs_right\", \"obstacle_front\", \"obs_front\")",
