    "SetTransition(\"recent_rot\", \"obstacle_left\", \"obs_left\")",
    "SetTransition(\"recent_rot\", \"obstacle_right\", \"obs_right\")",
    "SetTransition(\"clear\", \"move_forward\", \"clear\")",
    "SetTransition(\"clear\", \"random_walk\", \"clear\")",
    "SetTransition(\"clear\", \"rotate_clockwise\", \"recent_rot\")",
    "SetTransition(\"clear\", \"rotate_counterclockwise\", \"recent_rot\")",
    "SetTransition(\"clear\", \"full_rotate\", \"recent_rot\")",
    "SetTransition(\"obs_front\", \"rotate_clockwise\", \"recent_rot\")",
