    "forward_commit",
    "rotate_commit_cw",
    "rotate_commit_ccw",
    "scan_full",
    "marker_track",
    "marker_approach",
    "recover_back",
    "recover_rotate_cw",
    "recover_rotate_ccw",
    "search_explore"
  ],
