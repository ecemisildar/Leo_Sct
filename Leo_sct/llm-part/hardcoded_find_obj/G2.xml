<model version="0.0" type="FSA" id="Untitled">
<data>
	<states>
    <state id="0" name="clear"           initial="True"  marked="True" x="300" y="200"/>
    <state id="1" name="obs_front"       initial="False" marked="True" x="500" y="100"/>
    <state id="2" name="obs_left"        initial="False" marked="True" x="100" y="350"/>
    <state id="3" name="obs_right"       initial="False" marked="True" x="500" y="350"/>
    <state id="4" name="marker_visible"  initial="False" marked="True" x="650" y="200"/>
    <state id="5" name="marker_reached"  initial="False" marked="True" x="650" y="400"/>
  </states>
  <events>
    <!-- uncontrollable: drive state transitions in G2 -->
    <event id="0" name="path_clear"              controllable="False" observable="True"/>
    <event id="1" name="obstacle_front"          controllable="False" observable="True"/>
    <event id="2" name="obstacle_left"           controllable="False" observable="True"/>
    <event id="3" name="obstacle_right"          controllable="False" observable="True"/>
    <event id="4" name="marker_seen"             controllable="False" observable="True"/>
    <event id="5" name="marker_lost"             controllable="False" observable="True"/>
    <event id="6" name="marker_close"            controllable="False" observable="True"/>
    <!-- controllable: self-loop on all G2 states -->
    <event id="7"  name="move_forward"           controllable="True"  observable="True"/>
    <event id="9"  name="rotate_clockwise"       controllable="True"  observable="True"/>
    <event id="10" name="rotate_counterclockwise" controllable="True" observable="True"/>
    <event id="11" name="move_to_marker"         controllable="True"  observable="True"/>
    <event id="12" name="random_walk"            controllable="True"  observable="True"/>
    <event id="13" name="full_rotate"            controllable="True"  observable="True"/>
    <event id="14" name="stop"                   controllable="True"  observable="True"/>
  </events>
  <transitions>
    <!-- ============================================================
         UNCONTROLLABLE TRANSITIONS
         Sensor events drive perception state changes.
         ============================================================ -->

    <!-- FROM clear (0) -->
    <transition source="0" target="0" event="0"/>  <!-- path_clear -> stay clear -->
    <transition source="0" target="1" event="1"/>  <!-- obstacle_front -> obs_front -->
    <transition source="0" target="2" event="2"/>  <!-- obstacle_left  -> obs_left  -->
    <transition source="0" target="3" event="3"/>  <!-- obstacle_right -> obs_right -->
    <transition source="0" target="4" event="4"/>  <!-- marker_seen    -> marker_visible -->
    <transition source="0" target="0" event="5"/>  <!-- marker_lost    -> stay clear -->
    <transition source="0" target="5" event="6"/>  <!-- marker_close   -> marker_reached -->

    <!-- FROM obs_front (1) -->
    <transition source="1" target="0" event="0"/>  <!-- path_clear     -> clear -->
    <transition source="1" target="1" event="1"/>  <!-- obstacle_front -> stay obs_front -->
    <transition source="1" target="2" event="2"/>  <!-- obstacle_left  -> obs_left -->
    <transition source="1" target="3" event="3"/>  <!-- obstacle_right -> obs_right -->
    <transition source="1" target="4" event="4"/>  <!-- marker_seen    -> marker_visible -->
    <transition source="1" target="1" event="5"/>  <!-- marker_lost    -> stay obs_front -->
    <transition source="1" target="5" event="6"/>  <!-- marker_close   -> marker_reached -->

    <!-- FROM obs_left (2) -->
    <transition source="2" target="0" event="0"/>  <!-- path_clear     -> clear -->
    <transition source="2" target="1" event="1"/>  <!-- obstacle_front -> obs_front -->
    <transition source="2" target="2" event="2"/>  <!-- obstacle_left  -> stay obs_left -->
    <transition source="2" target="3" event="3"/>  <!-- obstacle_right -> obs_right -->
    <transition source="2" target="4" event="4"/>  <!-- marker_seen    -> marker_visible -->
    <transition source="2" target="2" event="5"/>  <!-- marker_lost    -> stay obs_left -->
    <transition source="2" target="5" event="6"/>  <!-- marker_close   -> marker_reached -->

    <!-- FROM obs_right (3) -->
    <transition source="3" target="0" event="0"/>  <!-- path_clear     -> clear -->
    <transition source="3" target="1" event="1"/>  <!-- obstacle_front -> obs_front -->
    <transition source="3" target="2" event="2"/>  <!-- obstacle_left  -> obs_left -->
    <transition source="3" target="3" event="3"/>  <!-- obstacle_right -> stay obs_right -->
    <transition source="3" target="4" event="4"/>  <!-- marker_seen    -> marker_visible -->
    <transition source="3" target="3" event="5"/>  <!-- marker_lost    -> stay obs_right -->
    <transition source="3" target="5" event="6"/>  <!-- marker_close   -> marker_reached -->

    <!-- FROM marker_visible (4) -->
    <transition source="4" target="0" event="0"/>  <!-- path_clear     -> clear (obs resolved) -->
    <transition source="4" target="1" event="1"/>  <!-- obstacle_front -> obs_front (marker lost from view) -->
    <transition source="4" target="2" event="2"/>  <!-- obstacle_left  -> obs_left -->
    <transition source="4" target="3" event="3"/>  <!-- obstacle_right -> obs_right -->
    <transition source="4" target="4" event="4"/>  <!-- marker_seen    -> stay marker_visible -->
    <transition source="4" target="0" event="5"/>  <!-- marker_lost    -> clear -->
    <transition source="4" target="5" event="6"/>  <!-- marker_close   -> marker_reached -->

    <!-- FROM marker_reached (5) — absorbing: all events self-loop -->
    <transition source="5" target="5" event="0"/>
    <transition source="5" target="5" event="1"/>
    <transition source="5" target="5" event="2"/>
    <transition source="5" target="5" event="3"/>
    <transition source="5" target="5" event="4"/>
    <transition source="5" target="5" event="5"/>
    <transition source="5" target="5" event="6"/>

    <!-- ============================================================
         CONTROLLABLE TRANSITIONS — self-loop on all states
         G2 does not care what motion command is issued.
         ============================================================ -->

    <!-- move_forward self-loops -->
    <transition source="0" target="0" event="7"/>
    <transition source="1" target="1" event="7"/>
    <transition source="2" target="2" event="7"/>
    <transition source="3" target="3" event="7"/>
    <transition source="4" target="4" event="7"/>
    <transition source="5" target="5" event="7"/>

    <!-- rotate_clockwise self-loops -->
    <transition source="0" target="0" event="9"/>
    <transition source="1" target="1" event="9"/>
    <transition source="2" target="2" event="9"/>
    <transition source="3" target="3" event="9"/>
    <transition source="4" target="4" event="9"/>
    <transition source="5" target="5" event="9"/>

    <!-- rotate_counterclockwise self-loops -->
    <transition source="0" target="0" event="10"/>
    <transition source="1" target="1" event="10"/>
    <transition source="2" target="2" event="10"/>
    <transition source="3" target="3" event="10"/>
    <transition source="4" target="4" event="10"/>
    <transition source="5" target="5" event="10"/>

    <!-- move_to_marker self-loops -->
    <transition source="0" target="0" event="11"/>
    <transition source="1" target="1" event="11"/>
    <transition source="2" target="2" event="11"/>
    <transition source="3" target="3" event="11"/>
    <transition source="4" target="4" event="11"/>
    <transition source="5" target="5" event="11"/>

    <!-- random_walk self-loops -->
    <transition source="0" target="0" event="12"/>
    <transition source="1" target="1" event="12"/>
    <transition source="2" target="2" event="12"/>
    <transition source="3" target="3" event="12"/>
    <transition source="4" target="4" event="12"/>
    <transition source="5" target="5" event="12"/>

    <!-- full_rotate self-loops -->
    <transition source="0" target="0" event="13"/>
    <transition source="1" target="1" event="13"/>
    <transition source="2" target="2" event="13"/>
    <transition source="3" target="3" event="13"/>
    <transition source="4" target="4" event="13"/>
    <transition source="5" target="5" event="13"/>

    <!-- stop self-loops -->
    <transition source="0" target="0" event="14"/>
    <transition source="1" target="1" event="14"/>
    <transition source="2" target="2" event="14"/>
    <transition source="3" target="3" event="14"/>
    <transition source="4" target="4" event="14"/>
    <transition source="5" target="5" event="14"/>
  </transitions>
</data>
</model>
